#
# Shim that points the Rust `tvm-ffi-sys` build script at tir's own build/lib —
# the SAME libtvm_ffi.so that libtvm_compiler.so was built against — rather
# than a pip copy. This guarantees a single, consistent ffi global-function
# registry in the process. CMakeLists.txt prepends this directory to PATH and
# sets TIRX_LIB_DIR; for bare `cargo build` the repo-relative defaults apply.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$HERE/../../.." && pwd)"

LIBDIR="${TIRX_LIB_DIR:-$REPO/build/lib}"
INCDIR="${TIRX_INC_DIR:-$REPO/3rdparty/tvm-ffi/include}"

case "${1:-}" in
  --libdir)      echo "$LIBDIR" ;;
  --includedir)  echo "$INCDIR" ;;
  --cflags)      echo "-I$INCDIR" ;;
  --libs)        echo "-ltvm_ffi" ;;
  *)             echo "$LIBDIR" ;;
esac
